{
  "title": "Microservices RED",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "timeseries",
      "title": "RPS by service",
      "targets": [{ "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (job)" }]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by route",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))" }]
    },
    {
      "type": "timeseries",
      "title": "Error rate %",
      "targets": [{ "expr": "100 * sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[5m])) by (job) / sum(rate(http_request_duration_seconds_count[5m])) by (job)" }]
    }
  ]
}
